# Credenciais da API Telegram (obtenha em my.telegram.org)
API_ID=seu_api_id_aqui
API_HASH=sua_api_hash_aqui

# Nome da sessao (sem extensao, arquivo sera criado em data/)
SESSION_NAME=userbot_session

# Chat ID ou username para onde encaminhar ofertas
# Pode ser 'me' (mensagens salvas), um ID numerico ou @username
FORWARD_TO=me
